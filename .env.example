# このファイルを .env にコピーして使用してください
# cp .env.example .env

# ホストユーザー情報
# Linux で bind mount 時の所有権を揃えたい場合は、ホストの id に合わせて変更してください
USER_NAME=ros_developer
USER_ID=1000
USER_GID=1000

# ROS ドメイン（同一ネットワークで複数ロボットを使う場合に変更）
ROS_DOMAIN_ID=0

# ROS ミドルウェア
# WSL / Docker Desktop では rmw_cyclonedds_cpp の方が安定する場合があります
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# DDS 通信設定
# WSL / Docker Desktop で pub/sub 確認が不安定な場合に利用してください
ROS_LOCALHOST_ONLY=1
FASTDDS_BUILTIN_TRANSPORTS=UDPv4

# DISPLAY は Linux で GUI を使う場合に利用します
# 非 Linux で docker-compose.nonlinux.yml を使う場合は通常そのままで構いません
DISPLAY=:0
